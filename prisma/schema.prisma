generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CompanySettings {
  id                   Int      @id @default(autoincrement())
  name                 String   @default("DayFlow")
  logo                 String?
  address              String?
  phone                String?
  email                String?
  website              String?
  timezone             String   @default("Asia/Kolkata")
  workStartTime        String   @default("09:00")
  workEndTime          String   @default("18:00")
  weekendDays          Int[]    @default([0, 6])
  lateThreshold        Int      @default(30)
  halfDayHours         Float    @default(4.0)
  payrollCurrency      String   @default("INR")
  financialYearStart   Int      @default(4)
  updatedAt            DateTime @updatedAt
  allowedIps           String[] @default([])
  attendanceValidation String   @default("NONE")
  officeLat            Float?
  officeLng            Float?
  officeRadius         Int      @default(100)
}

model Department {
  id            Int               @id @default(autoincrement())
  name          String            @unique
  code          String            @unique
  description   String?
  headId        Int?
  parentId      Int?
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  announcements Announcement[]
  head          User?             @relation("DepartmentHead", fields: [headId], references: [id])
  parent        Department?       @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children      Department[]      @relation("DepartmentHierarchy")
  employees     EmployeeDetails[]
  jobPostings   JobPosting[]
  onboardingTemplates OnboardingTemplate[]
  goals         Goal[]
  workflows     ApprovalWorkflow[]
}

model Holiday {
  id          Int         @id @default(autoincrement())
  name        String
  date        DateTime    @db.Date
  type        HolidayType @default(COMPANY)
  isOptional  Boolean     @default(false)
  description String?
  createdAt   DateTime    @default(now())

  @@unique([date, name])
}

model User {
  id                      Int                     @id @default(autoincrement())
  employeeId              String                  @unique
  email                   String                  @unique
  password                String
  role                    Role                    @default(EMPLOYEE)
  isActive                Boolean                 @default(true)
  firstLogin              Boolean                 @default(true)
  emailVerified           Boolean                 @default(false)
  emailVerificationToken  String?
  emailVerificationExpiry DateTime?
  passwordResetToken      String?
  passwordResetExpiry     DateTime?
  twoFactorEnabled        Boolean                 @default(false)
  twoFactorSecret         String?
  lastLoginAt             DateTime?
  failedLoginAttempts     Int                     @default(0)
  accountLockedUntil      DateTime?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  managerId               Int?
  announcements           Announcement[]
  attendance              Attendance[]
  auditLogs               AuditLog[]
  departmentsHeaded       Department[]            @relation("DepartmentHead")
  documents               Document[]              @relation("DocumentOwner")
  documentsUploaded       Document[]              @relation("DocumentUploadedBy")
  details                 EmployeeDetails?
  leaveBalances           LeaveBalance[]
  leaves                  LeaveRequest[]
  messages                Message[]
  notifications           Notification[]
  notificationPreference  NotificationPreference?
  payrolls                Payroll[]
  salary                  SalaryStructure?
  sessions                Session[]
  ticketsAssigned         SupportTicket[]         @relation("TicketAssignedTo")
  ticketsRaised           SupportTicket[]         @relation("TicketRaisedBy")
  ticketMessages          TicketMessage[]
  passwordHistory         PasswordHistory[]
  passwordChangedAt       DateTime?
  manager                 User?                   @relation("ManagerReports", fields: [managerId], references: [id])
  reports                 User[]                  @relation("ManagerReports")
  
  // Phase 2 Relations
  jobsPosted              JobPosting[]            @relation("JobsPostedBy")
  applicationsReferred    Application[]           @relation("ApplicationsReferredBy")
  interviewsConducted     InterviewSchedule[]     @relation("InterviewsConducted")
  onboardingProgress      OnboardingProgress[]    @relation("OnboardingEmployee")
  onboardingTasksCompleted OnboardingProgress[]   @relation("OnboardingCompletedBy")
  offboarding             OffboardingProcess?     @relation("OffboardingEmployee")
  offboardingInitiated    OffboardingProcess[]    @relation("OffboardingInitiatedBy")
  exitInterview           ExitInterview?          @relation("ExitInterviewEmployee")
  exitInterviewsConducted ExitInterview[]         @relation("ExitInterviewConductedBy")

  // Phase 3 Relations
  taxDeclarations         TaxDeclaration[]        @relation("TaxDeclarations")
  taxReviewed             TaxDeclaration[]        @relation("TaxReviewedBy")
  form16s                 Form16[]                @relation("Form16s")
  settlement              Settlement?             @relation("SettlementEmployee")
  settlementsProcessed    Settlement[]            @relation("SettlementProcessor")

  // Phase 4 Relations
  goalsAssigned           Goal[]                  @relation("EmployeeGoals")
  goalsManaged            Goal[]                  @relation("ManagerAssignedGoals")
  performanceReviews      PerformanceReview[]     @relation("EmployeeReviews")
  performanceReviewsDone  PerformanceReview[]     @relation("ManagerReviews")
  feedbackGiven           Feedback[]              @relation("FeedbackProvided")
  feedbackReceived        Feedback[]              @relation("FeedbackReceived")

  // Phase 5 Relations
  leaveAccruals           LeaveAccrualLog[]       @relation("LeaveAccruals")

  // Phase 6 Relations
  approvalRequests        ApprovalRequest[]       @relation("ApprovalRequester")
  approvalSteps           ApprovalStep[]          @relation("Approver")
}

model EmployeeDetails {
  id                       Int         @id @default(autoincrement())
  userId                   Int         @unique
  firstName                String
  lastName                 String
  phone                    String?
  address                  String?
  profilePic               String?
  jobTitle                 String
  department               String
  joiningDate              DateTime
  aadharNumber             String?
  bankAccountNo            String?
  bankName                 String?
  bloodGroup               String?
  dateOfBirth              DateTime?
  departmentId             Int?
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  gender                   Gender?
  ifscCode                 String?
  maritalStatus            String?
  panNumber                String?
  uanNumber                String?
  departmentRef            Department? @relation(fields: [departmentId], references: [id])
  user                     User        @relation(fields: [userId], references: [id])
}

model SalaryStructure {
  id               Int   @id @default(autoincrement())
  userId           Int   @unique
  wage             Float
  basic            Float
  hra              Float
  stdAllowance     Float
  performanceBonus Float
  lta              Float
  fixedAllowance   Float
  pf               Float
  profTax          Float
  netSalary        Float
  user             User  @relation(fields: [userId], references: [id])
}

model Attendance {
  id         Int              @id @default(autoincrement())
  userId     Int
  date       DateTime         @db.Date
  checkIn    DateTime?
  checkOut   DateTime?
  status     AttendanceStatus @default(ABSENT)
  isLate     Boolean          @default(false)
  notes      String?
  totalHours Float?
  user       User             @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model LeaveRequest {
  id            Int         @id @default(autoincrement())
  userId        Int
  type          LeaveType
  startDate     DateTime
  endDate       DateTime
  reason        String
  status        LeaveStatus @default(PENDING)
  adminComments String?
  appliedAt     DateTime    @default(now())
  isHalfDay     Boolean     @default(false)
  reviewedAt    DateTime?
  reviewedBy    Int?
  totalDays     Float       @default(1)
  user          User        @relation(fields: [userId], references: [id])
}

model LeavePolicy {
  id                 Int       @id @default(autoincrement())
  leaveType          LeaveType @unique
  annualEntitlement  Int       @default(12)
  accrualRatePerMonth Float    @default(1.0)
  maxCarryForward    Int       @default(5)
  maxConsecutiveDays Int       @default(5)
  requiresApproval   Boolean   @default(true)
  minNoticeDays      Int       @default(1)
  isEncashable       Boolean   @default(false)
  isActive           Boolean   @default(true)
  description        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model LeaveAccrualLog {
  id              Int       @id @default(autoincrement())
  userId          Int
  leaveType       LeaveType
  month           Int
  year            Int
  accruedAmount   Float
  transactionDate DateTime  @default(now())
  description     String?

  user            User      @relation("LeaveAccruals", fields: [userId], references: [id])
}

model LeaveBalance {
  id           Int       @id @default(autoincrement())
  userId       Int
  leaveType    LeaveType
  year         Int
  entitled     Float     @default(0)
  used         Float     @default(0)
  pending      Float     @default(0)
  carryForward Float     @default(0)
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id])

  @@unique([userId, leaveType, year])
}

model Payroll {
  id               Int           @id @default(autoincrement())
  userId           Int
  month            Int
  year             Int
  daysInMonth      Int           @default(30)
  attendanceDays   Int           @default(0)
  weekendDays      Int           @default(0)
  leaveDays        Int           @default(0)
  payableDays      Int           @default(0)
  grossSalary      Float         @default(0)
  earnedGross      Float         @default(0)
  pfDeduction      Float         @default(0)
  profTaxDeduction Float         @default(0)
  esiDeduction     Float         @default(0)
  tdsDeduction     Float         @default(0)
  otherDeductions  Float         @default(0)
  baseWage         Float
  totalEarnings    Float
  totalDeductions  Float
  netPay           Float
  status           PayrollStatus @default(GENERATED)
  createdAt        DateTime      @default(now())
  holidayDays      Int           @default(0)
  user             User          @relation(fields: [userId], references: [id])

  @@unique([userId, month, year])
}

model Message {
  id        Int       @id @default(autoincrement())
  content   String
  userId    Int
  createdAt DateTime  @default(now())
  isEdited  Boolean   @default(false)
  editedAt  DateTime?
  readBy    Int[]     @default([])
  user      User      @relation(fields: [userId], references: [id])
}

model Announcement {
  id           Int                  @id @default(autoincrement())
  title        String
  content      String
  priority     AnnouncementPriority @default(NORMAL)
  createdById  Int
  departmentId Int?
  startsAt     DateTime             @default(now())
  expiresAt    DateTime?
  isPinned     Boolean              @default(false)
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  createdBy    User                 @relation(fields: [createdById], references: [id])
  department   Department?          @relation(fields: [departmentId], references: [id])
}

model SupportTicket {
  id           Int             @id @default(autoincrement())
  ticketNumber String          @unique @default(cuid())
  employeeId   Int
  category     TicketCategory
  subject      String
  description  String
  priority     TicketPriority  @default(MEDIUM)
  status       TicketStatus    @default(OPEN)
  assignedToId Int?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  resolvedAt   DateTime?
  closedAt     DateTime?
  assignedTo   User?           @relation("TicketAssignedTo", fields: [assignedToId], references: [id])
  employee     User            @relation("TicketRaisedBy", fields: [employeeId], references: [id])
  messages     TicketMessage[]
}

model TicketMessage {
  id             Int           @id @default(autoincrement())
  ticketId       Int
  senderId       Int
  content        String
  isInternal     Boolean       @default(false)
  attachmentUrl  String?
  attachmentName String?
  createdAt      DateTime      @default(now())
  sender         User          @relation(fields: [senderId], references: [id])
  ticket         SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Document {
  id            Int          @id @default(autoincrement())
  ownerId       Int?
  uploadedById  Int
  name          String
  type          DocumentType
  category      String?
  fileUrl       String
  fileSize      Int?
  mimeType      String?
  isCompanyWide Boolean      @default(false)
  isVerified    Boolean      @default(false)
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  owner         User?        @relation("DocumentOwner", fields: [ownerId], references: [id])
  uploadedBy    User         @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])
}

model Session {
  id           Int      @id @default(autoincrement())
  userId       Int
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  deviceName   String?
  deviceType   String?  @default("desktop")
  browser      String?
  os           String?
  isRevoked    Boolean  @default(false)
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  action     String
  resource   String
  resourceId String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  emailSent Boolean          @default(false)
  createdAt DateTime         @default(now())
  readAt    DateTime?
  user      User             @relation(fields: [userId], references: [id])
}

model NotificationPreference {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique
  emailLeaveUpdates     Boolean  @default(true)
  emailPayrollGenerated Boolean  @default(true)
  emailAnnouncements    Boolean  @default(true)
  emailAttendanceAlerts Boolean  @default(false)
  inAppLeaveUpdates     Boolean  @default(true)
  inAppPayrollGenerated Boolean  @default(true)
  inAppAnnouncements    Boolean  @default(true)
  inAppAttendanceAlerts Boolean  @default(true)
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id])
}

enum Role {
  ADMIN
  EMPLOYEE
  HR_MANAGER
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
  WEEKEND
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  SICK
  PAID
  UNPAID
  CASUAL
  MATERNITY
  PATERNITY
  BEREAVEMENT
  COMPENSATORY
}

enum PayrollStatus {
  GENERATED
  PAID
}

enum HolidayType {
  NATIONAL
  REGIONAL
  COMPANY
  OPTIONAL
}

enum NotificationType {
  LEAVE_APPROVED
  LEAVE_REJECTED
  PAYROLL_GENERATED
  ANNOUNCEMENT
  ATTENDANCE_REMINDER
  WELCOME
  PASSWORD_CHANGED
  PROFILE_UPDATED
  TICKET_CREATED
  TICKET_UPDATED
  TICKET_RESOLVED
  DOCUMENT_UPLOADED
  BIRTHDAY
  ANNIVERSARY
}

enum TicketCategory {
  PAYROLL_ISSUE
  LEAVE_DISCREPANCY
  ATTENDANCE_ISSUE
  IT_SUPPORT
  POLICY_QUESTION
  BENEFITS
  HARASSMENT_COMPLAINT
  WORKPLACE_SAFETY
  GENERAL_INQUIRY
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  AWAITING_RESPONSE
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum DocumentType {
  OFFER_LETTER
  APPOINTMENT_LETTER
  ID_PROOF
  ADDRESS_PROOF
  EDUCATION_CERTIFICATE
  EXPERIENCE_LETTER
  PAYSLIP
  TAX_FORM
  COMPANY_POLICY
  HANDBOOK
  NDA
  CONTRACT
  OTHER
}

model PasswordHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  hash      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// --- PHASE 2: ATS & ONBOARDING ---

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum JobStatus {
  DRAFT
  OPEN
  ON_HOLD
  CLOSED
}

enum ApplicationSource {
  WEBSITE
  LINKEDIN
  REFERRAL
  NAUKRI
  INDEED
  OTHER
}

enum ApplicationStatus {
  NEW
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum InterviewRecommendation {
  HIRE
  NO_HIRE
  MAYBE
}

model JobPosting {
  id              Int           @id @default(autoincrement())
  title           String
  description     String        @db.Text
  departmentId    Int?
  location        String?
  employmentType  EmploymentType @default(FULL_TIME)
  experienceMin   Int?
  experienceMax   Int?
  salaryRangeMin  Int?
  salaryRangeMax  Int?
  skills          String[]      @default([])
  status          JobStatus     @default(DRAFT)
  postedById      Int?
  postedAt        DateTime?
  closingDate     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  department      Department?   @relation(fields: [departmentId], references: [id])
  postedBy        User?         @relation("JobsPostedBy", fields: [postedById], references: [id])
  applications    Application[]
}

model Application {
  id              Int               @id @default(autoincrement())
  jobPostingId    Int
  candidateName   String
  candidateEmail  String
  candidatePhone  String?
  resumeUrl       String?
  coverLetterUrl  String?
  source          ApplicationSource @default(WEBSITE)
  status          ApplicationStatus @default(NEW)
  stage           String?           @default("Applied")
  rating          Int?
  notes           String?           @db.Text
  referredById    Int?
  appliedAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  jobPosting      JobPosting        @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  referredBy      User?             @relation("ApplicationsReferredBy", fields: [referredById], references: [id])
  interviews      InterviewSchedule[]
}

model InterviewSchedule {
  id              Int               @id @default(autoincrement())
  applicationId   Int
  interviewerId   Int
  roundName       String
  scheduledAt     DateTime
  durationMinutes Int               @default(60)
  meetingLink     String?
  status          InterviewStatus   @default(SCHEDULED)
  feedback        String?           @db.Text
  rating          Int?
  recommendation  InterviewRecommendation?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  application     Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  interviewer     User              @relation("InterviewsConducted", fields: [interviewerId], references: [id])
}

enum OnboardingTaskCategory {
  DOCUMENT
  IT_SETUP
  TRAINING
  POLICY_ACK
  BUDDY
  WELCOME
}

enum OnboardingTaskStatus {
  PENDING
  COMPLETED
  SKIPPED
}

model OnboardingTemplate {
  id            Int               @id @default(autoincrement())
  name          String
  departmentId  Int?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  department    Department?       @relation(fields: [departmentId], references: [id])
  tasks         OnboardingTask[]
}

model OnboardingTask {
  id            Int                    @id @default(autoincrement())
  templateId    Int
  title         String
  description   String?                @db.Text
  assignedRole  Role                   @default(EMPLOYEE) // Who does this task? HR, IT, Manager, Employee
  dueInDays     Int                    @default(0) // Days from joining date
  isRequired    Boolean                @default(true)
  category      OnboardingTaskCategory @default(WELCOME)
  
  template      OnboardingTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  progress      OnboardingProgress[]
}

model OnboardingProgress {
  id            Int                  @id @default(autoincrement())
  employeeId    Int
  taskId        Int
  status        OnboardingTaskStatus @default(PENDING)
  completedAt   DateTime?
  completedById Int?
  notes         String?              @db.Text
  
  employee      User                 @relation("OnboardingEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  completedBy   User?                @relation("OnboardingCompletedBy", fields: [completedById], references: [id])
  task          OnboardingTask       @relation(fields: [taskId], references: [id], onDelete: Cascade)
}


enum OffboardingReason {
  RESIGNATION
  TERMINATION
  RETIREMENT
  CONTRACT_END
}

enum OffboardingStatus {
  INITIATED
  IN_PROGRESS
  COMPLETED
}

model OffboardingProcess {
  id                      Int               @id @default(autoincrement())
  employeeId              Int               @unique
  initiatedById           Int
  lastWorkingDate         DateTime          @db.Date
  reason                  OffboardingReason
  status                  OffboardingStatus @default(INITIATED)
  exitInterviewCompleted  Boolean           @default(false)
  assetReturnStatus       Boolean           @default(false)
  knowledgeTransferStatus Boolean           @default(false)
  finalSettlementStatus   Boolean           @default(false)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  employee                User              @relation("OffboardingEmployee", fields: [employeeId], references: [id])
  initiatedBy             User              @relation("OffboardingInitiatedBy", fields: [initiatedById], references: [id])
  settlement              Settlement?
}

model ExitInterview {
  id                Int      @id @default(autoincrement())
  employeeId        Int      @unique
  conductedById     Int?
  reasonForLeaving  String   @db.Text
  feedback          String   @db.Text
  wouldRecommend    Boolean  @default(true)
  suggestions       String?  @db.Text
  createdAt         DateTime @default(now())

  employee          User     @relation("ExitInterviewEmployee", fields: [employeeId], references: [id])
  conductedBy       User?    @relation("ExitInterviewConductedBy", fields: [conductedById], references: [id])
}

// ------------------------------------------------------
// PHASE 3: ADVANCED PAYROLL & TAX COMPLIANCE
// ------------------------------------------------------

enum StatutoryType {
  PF
  ESI
  PT
  LWF
  TDS
  GRATUITY
}

model StatutoryConfig {
  id                    Int           @id @default(autoincrement())
  type                  StatutoryType
  employeeContribution  Float         @default(0) // Percentage or fixed amount
  employerContribution  Float         @default(0) // Percentage or fixed amount
  ceiling               Float?        // e.g., max 15000 for PF
  isActive              Boolean       @default(true)
  effectiveFrom         DateTime      @default(now())
  state                 String?       // For PT, since it varies by state
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model TaxDeclaration {
  id              Int      @id @default(autoincrement())
  employeeId      Int
  financialYear   String   // e.g., "2026-2027"
  section80C      Float    @default(0)
  section80D      Float    @default(0)
  hra             Float    @default(0)
  otherDeductions Float    @default(0)
  proofUrls       String[]
  status          String   @default("SUBMITTED") // SUBMITTED, APPROVED, REJECTED
  reviewedBy      Int?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee        User     @relation("TaxDeclarations", fields: [employeeId], references: [id])
  reviewer        User?    @relation("TaxReviewedBy", fields: [reviewedBy], references: [id])
}

model Form16 {
  id              Int      @id @default(autoincrement())
  employeeId      Int
  financialYear   String
  fileUrl         String
  generatedAt     DateTime @default(now())

  employee        User     @relation("Form16s", fields: [employeeId], references: [id])
}

model Settlement {
  id                 Int      @id @default(autoincrement())
  employeeId         Int      @unique
  offboardingId      Int      @unique
  leaveEncashment    Float    @default(0)
  gratuity           Float    @default(0)
  bonus              Float    @default(0)
  noticePeriodDeduction Float @default(0)
  assetDamageDeduction  Float @default(0)
  loanBalance        Float    @default(0)
  totalAmount        Float    @default(0)
  status             String   @default("DRAFT") // DRAFT, PROCESSED, PAID
  processedBy        Int?
  processedAt        DateTime?

  employee           User     @relation("SettlementEmployee", fields: [employeeId], references: [id])
  offboarding        OffboardingProcess @relation(fields: [offboardingId], references: [id])
  processor          User?    @relation("SettlementProcessor", fields: [processedBy], references: [id])
}

// ------------------------------------------------------
// PHASE 4: PERFORMANCE & OKR MANAGEMENT
// ------------------------------------------------------

enum GoalStatus {
  NOT_STARTED
  ON_TRACK
  AT_RISK
  OFF_TRACK
  COMPLETED
}

model Goal {
  id              Int         @id @default(autoincrement())
  title           String
  description     String?     @db.Text
  targetDate      DateTime?
  progress        Int         @default(0) // 0 to 100
  status          GoalStatus  @default(NOT_STARTED)
  employeeId      Int
  managerId       Int?
  departmentId    Int?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  employee        User        @relation("EmployeeGoals", fields: [employeeId], references: [id])
  manager         User?       @relation("ManagerAssignedGoals", fields: [managerId], references: [id])
  department      Department? @relation(fields: [departmentId], references: [id])
}

enum ReviewStatus {
  DRAFT
  SELF_ASSESSMENT_PENDING
  MANAGER_ASSESSMENT_PENDING
  COMPLETED
}

model PerformanceReview {
  id                  Int          @id @default(autoincrement())
  title               String       // e.g., "Q1 2026 Appraisal"
  employeeId          Int
  managerId           Int
  selfRating          Int?         // 1 to 5
  selfComments        String?      @db.Text
  managerRating       Int?         // 1 to 5
  managerComments     String?      @db.Text
  status              ReviewStatus @default(DRAFT)
  dueDate             DateTime?
  completedAt         DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  employee            User         @relation("EmployeeReviews", fields: [employeeId], references: [id])
  manager             User         @relation("ManagerReviews", fields: [managerId], references: [id])
}

model Feedback {
  id              Int      @id @default(autoincrement())
  providerId      Int
  receiverId      Int
  content         String   @db.Text
  isAnonymous     Boolean  @default(false)
  createdAt       DateTime @default(now())

  provider        User     @relation("FeedbackProvided", fields: [providerId], references: [id])
  receiver        User     @relation("FeedbackReceived", fields: [receiverId], references: [id])
}

// ------------------------------------------------------
// PHASE 6: MULTI-LEVEL APPROVALS
// ------------------------------------------------------

enum WorkflowType {
  LEAVE
  EXPENSE
  APPRAISAL
  OTHER
}

model ApprovalWorkflow {
  id              Int       @id @default(autoincrement())
  name            String
  type            WorkflowType
  departmentId    Int?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  department      Department? @relation(fields: [departmentId], references: [id])
  requests        ApprovalRequest[]
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model ApprovalRequest {
  id              Int       @id @default(autoincrement())
  workflowId      Int
  requesterId     Int
  entityId        Int       // ID of the LeaveRequest, Expense, etc.
  status          ApprovalStatus @default(PENDING)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workflow        ApprovalWorkflow @relation(fields: [workflowId], references: [id])
  requester       User             @relation("ApprovalRequester", fields: [requesterId], references: [id])
  steps           ApprovalStep[]
}

model ApprovalStep {
  id              Int       @id @default(autoincrement())
  requestId       Int
  approverId      Int
  stepOrder       Int       // 1, 2, 3...
  status          ApprovalStatus @default(PENDING)
  comments        String?   @db.Text
  actedAt         DateTime?

  request         ApprovalRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approver        User             @relation("Approver", fields: [approverId], references: [id])
}
